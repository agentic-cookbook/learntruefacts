{
  "name": "learn-true-facts-main",
  "main": "src/worker.ts",
  "compatibility_date": "2024-12-01",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "learntruefacts.ai",
      "custom_domain": true
    }
  ],
  "vars": {
    "API_BACKEND_URL": "https://learn-true-facts-production.up.railway.app"
  }
}
