{
  "name": "learn-true-facts-dashboard",
  "main": "worker/index.ts",
  "compatibility_date": "2024-12-01",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "learn-true-facts-dashboard-db",
      "database_id": "a94bf3b6-a082-4cde-a109-53a0e4864780"
    }
  ],
  "vars": {
    "API_BACKEND_URL": "https://backend-production-c42c9.up.railway.app",
    "MAIN_SITE_URL": "https://learntruefacts.ai",
    "ADMIN_SITE_URL": "https://admin.learntruefacts.ai"
  }
}
