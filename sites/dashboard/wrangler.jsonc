{
  "name": "learn-true-facts-dashboard",
  "main": "worker/index.ts",
  "compatibility_date": "2024-12-01",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "dashboard.learntruefacts.ai",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "learn-true-facts-dashboard-db",
      "database_id": "placeholder-run-wrangler-d1-create"
    }
  ],
  "triggers": {
    "crons": [
      "*/1 * * * *",
      "*/5 * * * *",
      "0 * * * *"
    ]
  },
  "vars": {
    "API_BACKEND_URL": "https://learn-true-facts-production.up.railway.app",
    "MAIN_SITE_URL": "https://learntruefacts.ai",
    "ADMIN_SITE_URL": "https://admin.learntruefacts.ai"
  }
}
